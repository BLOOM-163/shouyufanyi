<view class="container">
  <view class="header">
    <text class="title">历史记录</text>
    <button class="btn-small" bindtap="clearHistory">清空</button>
  </view>

  <view wx:if="{{historyList.length === 0}}" class="empty-state">
    <text class="empty-icon">📝</text>
    <text class="empty-text">暂无历史记录</text>
  </view>

  <view wx:else class="history-list">
    <view wx:for="{{historyList}}" wx:key="index" class="history-item">
      <view class="item-header">
        <text class="item-gesture">{{item.gesture}}</text>
        <text class="item-time">{{item.time}}</text>
      </view>
      <view class="item-body">
        <view class="location-info">
          <text class="location-label">位置:</text>
          <text class="location-value">{{item.gps.latitude}}, {{item.gps.longitude}}</text>
        </view>
        <view wx:if="{{item.gps.speed > 0}}" class="speed-info">
          <text class="speed-label">速度:</text>
          <text class="speed-value">{{item.gps.speed}} km/h</text>
        </view>
      </view>
    </view>
  </view>

  <view class="back-button">
    <button class="btn" bindtap="goBack">返回首页</button>
  </view>
</view>