<view class="container">
  <view class="header">
    <text class="title">手语翻译系统</text>
    <view class="status-badge {{isConnected ? 'connected' : 'disconnected'}}">
      <text>{{isConnected ? '已连接' : '未连接'}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-header">
      <text class="card-title">手语识别结果</text>
    </view>
    <view class="card-body">
      <view class="gesture-display">
        <text class="gesture-text">{{gestureText || '等待识别...'}}</text>
      </view>
      <view wx:if="{{warningMessage}}" class="warning-box">
        <text class="warning-icon">⚠️</text>
        <text class="warning-text">{{warningMessage}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-header">
      <text class="card-title">GPS定位信息</text>
    </view>
    <view class="card-body">
      <view class="info-row">
        <text class="info-label">纬度:</text>
        <text class="info-value">{{gpsData.latitude || '--'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">经度:</text>
        <text class="info-value">{{gpsData.longitude || '--'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">海拔:</text>
        <text class="info-value">{{gpsData.altitude ? gpsData.altitude + 'm' : '--'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">速度:</text>
        <text class="info-value">{{gpsData.speed ? gpsData.speed + 'km/h' : '--'}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-header">
      <text class="card-title">系统状态</text>
    </view>
    <view class="card-body">
      <view class="status-item">
        <text class="status-label">设备状态:</text>
        <text class="status-value {{isConnected ? 'success' : 'error'}}">
          {{isConnected ? '在线' : '离线'}}
        </text>
      </view>
      <view class="status-item">
        <text class="status-label">GPS状态:</text>
        <text class="status-value {{gpsData.valid ? 'success' : 'warning'}}">
          {{gpsData.valid ? '已定位' : '未定位'}}
        </text>
      </view>
      <view class="status-item">
        <text class="status-label">手部检测:</text>
        <text class="status-value {{handDetected ? 'success' : 'warning'}}">
          {{handDetected ? '检测到' : '未检测到'}}
        </text>
      </view>
      <view class="status-item">
        <text class="status-label">更新时间:</text>
        <text class="status-value">{{updateTime || '--:--:--'}}</text>
      </view>
    </view>
  </view>

  <view class="action-buttons">
    <button class="btn" bindtap="refreshData">刷新数据</button>
    <button class="btn btn-secondary" bindtap="viewHistory">查看历史</button>
    <button class="btn btn-outline" bindtap="openSettings">设置</button>
  </view>
</view>